# --- Hardware Resource Crash Monitor ---
# (run during games or other apps to log hardware health)
alias hw-start="sudo systemctl start hw_monitor.service"
alias hw-stop="sudo systemctl stop hw_monitor.service"

hw-watch() {
    (   
        echo "Starting hw_monitor.service..."
        sudo systemctl start hw_monitor.service
        # Ensure the service is stopped when hitting Ctrl+C (INT) or exiting
        trap 'echo -e "\nStopping hw_monitor.service..."; sudo systemctl stop hw_monitor.service' EXIT INT TERM
        # Watch the hardware resource log in real-time
        tail -f ~/logs/hw_metrics_log.csv
    )
}

# ==============================================================================
# --- Dev Containers ---
# ==============================================================================

# Generic Helper: Connects to a matching running Dev Container
_dev_container_exec() {
    local name_match="$1"
    local work_dir="$2"
    shift 2 # Shift arguments so whatever remains becomes the command
    local cmd=("$@")

    local cid
    cid=$(docker ps | grep -i "$name_match" | head -n 1 | awk '{print $1}')

    if [ -z "$cid" ]; then
        echo "❌ Error: The '$name_match' dev container is not currently running."
        return 1
    fi

    docker exec -it --user vscode -w "$work_dir" "$cid" "${cmd[@]}"
}

