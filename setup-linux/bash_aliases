# --- Custom Workflows ---
# Gracefully restart Steam to load newly installed Proton GE versions
steam-rl() {
    echo "Shutting down Steam..."
    steam -shutdown > /dev/null 2>&1

    # Wait continuously for the Steam process to fully drop out of memory
    while pgrep -u "$USER" -x steam > /dev/null; do
        sleep 1
    done

    echo "Starting Steam in the background..."
    steam < /dev/null > /dev/null 2>&1 &
    disown
}

