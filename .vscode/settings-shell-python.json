{
  // =========================================================================
  // UI & WORKBENCH (Top-to-Bottom, Left-to-Right)
  // =========================================================================

  // --- Window & Overall Theme ---
  "workbench.colorTheme": "Dark Modern",
  "workbench.iconTheme": "vscode-icons",
  "vsicons.dontShowNewVersionMessage": true,
  "workbench.startupEditor": "none",
  "workbench.editor.labelFormat": "short",
  "window.density.editorTabHeight": "compact",

  // --- Activity Bar: Explorer ---
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.fileNesting.enabled": true,
  "files.associations": {
    "Dockerfile": "dockerfile",
    "bash_aliases": "shellscript",
    "hosts": "ini",
    "config": "ini",
    "*.json": "jsonc"
  },

  // --- Activity Bar: Source Control (Git) ---
  "git.enabled": true,
  "git.blame.statusBarItem.enabled": false,
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  "git.openRepositoryInParentFolders": "always",
  "diffEditor.ignoreTrimWhitespace": false,
  "merge-conflict.codeLens.enabled": false,

  // --- Code Editor (Global) ---
  "editor.minimap.enabled": true,
  "editor.fontFamily": "Consolas, 'Courier New', monospace",
  "editor.fontLigatures": false,
  "editor.wordWrapColumn": 160,
  "editor.inlayHints.enabled": "offUnlessPressed",
  "editor.accessibilitySupport": "off",
  "editor.linkedEditing": true,
  "editor.formatOnSave": true,
  "editor.formatOnPaste": true,
  "editor.codeActionsOnSave": {},

  // --- Panel: Terminal ---
  "terminal.explorerKind": "external",
  "terminal.integrated.defaultProfile.linux": "zsh",
  "terminal.integrated.defaultProfile.windows": "pwsh",

  // =========================================================================
  // LANGUAGES & FRAMEWORKS
  // =========================================================================

  // -------- Global default formatter (Prettier) --------
  // Covers JSON, YAML, and Markdown by default
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "prettier.printWidth": 160,
  "prettier.tabWidth": 2,
  "prettier.ignorePath": ".prettierignore",

  // -------- Config & Markdown (JSON, YAML, MD) --------
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "markdownlint.config": {
    "MD007": { "indent": 2 },
    "MD030": { "ul_single": 1, "ul_multi": 1 }
  },

  "[yaml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "yaml.format.printWidth": 160,
  "yaml.format.singleQuote": true,
  "yaml.format.bracketSpacing": true,
  "yaml.format.proseWrap": "preserve",

  // -------- Shell & PowerShell --------
  "[shellscript]": {
    "editor.defaultFormatter": "mkhl.shfmt",
    "editor.tabSize": 4,
    "editor.insertSpaces": true
  },
  "shfmt.executablePath": "/usr/bin/shfmt",
  "shfmt.executableArgs": [
    "-i", "4",  // Indent with 4 spaces
    "-ci",  // Indent switch cases
    "-bn",  // Binary operators (&& and |) may start a line
    "-sr",  // Space after redirect operators (>)
    "-kp"  // Keep padding, preserves alignment spacing in comments
  ],

  "[powershell]": {
    "editor.defaultFormatter": "ms-vscode.powershell"
  },
  "powershell.integratedConsole.showOnStartup": false,
  "powershell.promptToUpdatePowerShell": false,
  // https://til.intrepidintegration.com/vscode/powershell-settings
  "powershell.codeFormatting.autoCorrectAliases": true,
  "powershell.codeFormatting.trimWhitespaceAroundPipe": true,
  "powershell.codeFormatting.useCorrectCasing": true,
  "powershell.codeFormatting.newLineAfterOpenBrace": false,
  "powershell.codeFormatting.whitespaceBeforeOpenParen": true,
  "powershell.codeFormatting.ignoreOneLineBlock": true,
  "powershell.codeFormatting.newLineAfterCloseBrace": true,
  "powershell.codeFormatting.alignPropertyValuePairs": true,
  "powershell.codeFormatting.whitespaceAfterSeparator": true,
  "powershell.codeFormatting.openBraceOnSameLine": false,

  // -------- Python --------
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.codeActionsOnSave": {
      "source.fixAll": "explicit",
      "source.organizeImports": "explicit"
    }
  },
  "python.defaultInterpreterPath": "/usr/local/bin/python",
  "python-envs.defaultEnvManager": "ms-python.python:system",
  "python.analysis.autoImportCompletions": true,
  "python.analysis.typeCheckingMode": "basic",
  // Explicitly tell Pylance where module roots are for Quick Fix (Ctrl+.) auto-imports
  "python.analysis.extraPaths": [
    "${workspaceFolder}/python/modules",
    "${workspaceFolder}/python/modules/boilerplates",
    "${workspaceFolder}/docker/pc-ops/scripts"
  ],
  // https://code.visualstudio.com/docs/python/testing
  "python.testing.autoTestDiscoverOnSaveEnabled": true,
  "python.testing.pytestEnabled": true,
  "python.testing.pytestArgs": ["python"],  // repo subdirectory

  // =========================================================================
  // TELEMETRY & SYSTEM
  // =========================================================================

  "redhat.telemetry.enabled": false,

  // =========================================================================
  // VS Code AI (GitHub Copilot, Continue+Ollama)
  // Goal: Keep AI limited to manual chat usage with readonly access.
  // Disable agents, auto-actions, terminal execution, and intrusive editing.
  // =========================================================================

  // -------- Agents / Automation --------
  // Disable autonomous agent workflows
  "chat.agent.enabled": false,
  // Disable automatic AI fix actions
  "github.copilot.chat.agent.autoFix": false,

  // -------- Terminal Safety --------
  // Ignore built-in auto-approved commands
  "chat.tools.terminal.ignoreDefaultAutoApproveRules": true,
  // Require approval for ALL commands
  "chat.tools.terminal.autoApprove": {
    "/.*/": false
  },

  // -------- Editor AI Behavior --------
  "continue.showInlineTip": false,
  // Disable predictive edit suggestions
  "github.copilot.nextEditSuggestions.enabled": false,
  // Disable AI quick fixes/refactors
  "github.copilot.editor.enableCodeActions": false,
  // Disable automatic rename suggestions
  "github.copilot.renameSuggestions.triggerAutomatically": false
}
