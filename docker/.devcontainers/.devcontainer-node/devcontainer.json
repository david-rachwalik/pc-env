// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/typescript-node
// https://code.visualstudio.com/docs/devcontainers/tips-and-tricks
{
  "name": "Ubuntu NodeJS",
  // Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
  // "image": "mcr.microsoft.com/devcontainers/typescript-node:20",
  // Chose the Ubuntu container to best match web app host
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",

  "containerEnv": {
    // --- Development Environment Only ---
    // Disable Mangling: live reloads will build faster at cost of bundle size (not minified but more readable)
    "NG_BUILD_MANGLE": "false"
  },

  // Features to add to the dev container. More info: https://containers.dev/features.
  "features": {
    "ghcr.io/devcontainers/features/node:2.1.0": {
      "version": "20"
    }
  },

  // Use 'forwardPorts' to make a list of ports inside the container available locally.
  "forwardPorts": [4200],

  // Use 'postCreateCommand' to run commands after the container is created.
  // "postCreateCommand": "uname -a",
  // "postCreateCommand": "npm i && cd client-angular && npm i",

  //   "mounts": [
  //     "source=${localWorkspaceFolder}/python/modules/active,target=/home/codespace/.local/lib/python3.12/site-packages,type=bind,consistency=cached"
  //   ],
  // "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}", // This is usually the default

  // https://code.visualstudio.com/remote/advancedcontainers/add-local-file-mount
  "mounts": [
    "source=${localEnv:HOME}/.ssh,target=/home/vscode/.ssh,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.continue,target=/home/vscode/.continue,type=bind,consistency=cached"
  ],

  "runArgs": [
    // Allow services running on Ollama host to be accessed
    // > docker network create shared-dev-net
    "--network=shared-dev-net"
  ],

  // Configure tool-specific properties
  "customizations": {
    "vscode": {
      // Add the IDs of extensions to install when container is created
      "extensions": [
        // -------- Core / Docker / Formatting --------
        "ms-vscode-remote.remote-containers",
        "ms-azuretools.vscode-containers",  // Docker
        "esbenp.prettier-vscode",  // formatter

        // -------- Web Stack (JS, TS, HTML, CSS) --------
        "dbaeumer.vscode-eslint",  // linter
        "Angular.ng-template",
        // "Vue.volar",
        "bradlc.vscode-tailwindcss",

        // -------- Config & Markdown --------
        "DavidAnson.vscode-markdownlint",
        "redhat.vscode-yaml",
        "mikestead.dotenv",
        // "hashicorp.terraform",

        // -------- Utilities & UI --------
        "natqe.reload",
        "vscode-icons-team.vscode-icons",
        "donjayamanne.githistory",
        "bierner.markdown-preview-github-styles",
        "wayou.vscode-todo-highlight",
        // "mongodb.mongodb-vscode",
        // "theumletteam.umlet",
        // "42Crunch.vscode-openapi",
        "Continue.continue"
      ]
    }
  }

  // Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
  // "remoteUser": "root"
}
