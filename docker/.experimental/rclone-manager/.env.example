# ================================================================
# rclone-manager Configuration
# ================================================================

# User and Group ID. Run `id -u` and `id -g` on your host to find these.
PUID=1000
PGID=1000

# Your local timezone (e.g., America/New_York, Europe/London)
# Find yours by running: timedatectl list-timezones
TZ=America/New_York

# Web UI Port. Change this to avoid conflicts with other services.
# With 8686, you can bookmark http://localhost:8686
WEB_PORT=8686

# ================================================================
# Local Sync Directories (MUST be absolute paths on your computer)
# ================================================================
# The rclone-manager UI will use these exact paths for bisync.

ONEDRIVE_DIR=/home/your-user/OneDrive
PCLOUD_DIR=/home/your-user/pCloud
GDRIVE_DIR=/home/your-user/ObsidianVaults
