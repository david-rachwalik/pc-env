# Master Configuration for yt-dlp (and youtube-dl) settings

# https://github.com/yt-dlp/yt-dlp#configuration
# https://github.com/ytdl-org/youtube-dl/#configuration (old)

# The app `yt-dlp` supports multiple configuration file locations:
# - %APPDATA%\yt-dlp\config
# - %USERPROFILE%\youtube-dl.conf (old)

# The old config is still supported, but yt-dlp will prioritize settings from the first path if both exist.


# --- Do NOT specify player_client when using cookies ---
# Let yt-dlp auto-select the best client based on cookies
# Android/iOS clients don't support cookies, causing auth failures

# Deno strongly recommended over Node.js for security and compatibility
# (runs in sandboxed environment and supports newer ECMAScript features)
--js-runtimes deno

# --- Input format selection (default=bv*+ba/b) ---
# Select best formats for video (1080p resolution) and audio (128 kbps bitrate) with graceful fallbacks
# -f "bv*[height<=1080]+ba[abr<=128k]/b[height<=1080][abr<=128k]"
# --format "bestvideo*[height<=1080]+bestaudio[abr<=128k]/best[height<=1080][abr<=128k]"
--format "bv*[height<=1080]+ba/b"

# Further refine sorting preference
# -S codec:vp9:m4a,res:1080  # Prioritize video codec and resolution
# NOTE: yt-dlp already follows a built-in preference order: VP9 and AV1 (if available) over AVC1 (H.264)
# --format-sort "res,ext:mp4:m4a" # prefers MP4 over WebM and highest resolution if multiple are available


# --- Output settings ---
--merge-output-format mkv
--output "/mnt/d/_Downloads/[%(channel)s] %(title)s.%(ext)s"  # Save to Downloads directory
# Use `--remux-video mkv` if wanting to force an extension even when no merge occurs


# --- FFmpeg post-processing options ---
# Convert thumbnails to JPG format (more compatible than WebP)
--convert-thumbnails jpg
# Embed thumbnail in video file (works for MP4/MKV/M4A)
--embed-thumbnail
# Embed subtitles directly into MKV files (if downloaded)
--embed-subs
# Embed chapter markers (if available)
--embed-chapters
# Remove any pre-existing metadata to avoid conflicts before re-embedding
--parse-metadata ":(?P<meta_description>)"
--parse-metadata ":(?P<meta_comment>)"

# Specify FFmpeg location (if using multiple versions)
# --ffmpeg-location /usr/bin/ffmpeg

# Post-processing arguments for FFmpeg (preserve quality during re-encoding)
# -c:v copy = copy video stream without re-encoding
# -c:a copy = copy audio stream without re-encoding
# --postprocessor-args "ffmpeg:-c:v copy -c:a copy"

# For audio-only: normalize volume and remove silence
# --postprocessor-args "ffmpeg:-af loudnorm"

# --- Audio settings ---
--audio-format mp3      # Save audio as mp3
# --audio-quality 0       # Best audio quality (I prefer 128 kbps)

# --- Subtitles settings ---
# --write-subs            # Downloads subtitles (if available)
# --sub-lang en           # Downloads English subtitles
# --sub-format srt        # Saves subtitles in SRT format
# --write-auto-subs       # Download auto-generated subs if manual ones aren't available

# --- Metadata and info settings ---
--add-metadata          # Embeds metadata (including chapters)
# --write-info-json       # Saves additional video information in a .info.json file, which includes chapters and timestamps
# Time settings
# --no-mtime              # Do not copy the mtime (use download time instead of upload time)

# --- Credentials (to download age-restricted content or other flagged videos) ---
--cookies-from-browser firefox

# Spoof the request as a browser to bypass any potential restrictions
# yt-dlp --dump-user-agent
# --user-agent "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/93.0.4577.82 Safari/537.36"

# --- Robustness / fallback behavior ---
--ignore-errors # Lets batch jobs continue if one fails
--no-abort-on-error
--check-formats # Prevents hard failure when a preferred stream doesn't exist
# --retries infinite
# --fragment-retries infinite


# [COMMON COMMANDS]
# yt-dlp <URL>                                  # Main download method
# yt-dlp -F <URL>                               # View source information (available formats) rather than download
# yt-dlp -x -f "ba[abr<=128k]" <URL>            # Download audio only
# yt-dlp --list-formats-as-table <URL>          # Show formats in a readable table
